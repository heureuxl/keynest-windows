<Window x:Class="KeyNestForWin.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑条目"
        Height="520" Width="440"
        MinHeight="420" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.WindowBg}">
    <Border Background="{StaticResource Brush.WindowBg}" Padding="16">
        <Border Background="{StaticResource Brush.SurfaceElevated}"
                CornerRadius="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="20,18">
            <Border.Effect>
                <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="20" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="条目详情" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="扩展填充使用用户名与密码"
                               FontSize="11" Foreground="{StaticResource Brush.TextMuted}"/>
                    <CheckBox x:Name="FavoriteCheck" Content="收藏"
                              Margin="0,10,0,0" FontSize="12"
                              Foreground="{StaticResource Brush.TextMuted}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="标题" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox x:Name="TitleBox" Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Text="用户名" Style="{StaticResource FormLabelStyle}" Margin="0,10,0,0"/>
                        <TextBox x:Name="UsernameBox" Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Text="密码" Style="{StaticResource FormLabelStyle}" Margin="0,10,0,0"/>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="PasswordBox" Grid.Column="0"
                                         Style="{StaticResource FormPasswordBoxStyle}"/>
                            <TextBox x:Name="PasswordPlain" Grid.Column="0"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     Visibility="Collapsed"/>
                            <Button x:Name="PasswordToggle" Grid.Column="1" Content="显示"
                                    Click="PasswordToggle_Click"
                                    Style="{StaticResource GhostButtonStyle}"
                                    MinWidth="48" MinHeight="34" Margin="6,0,0,0"
                                    Padding="8,4" FontSize="12"/>
                        </Grid>

                        <TextBlock Text="网站" Style="{StaticResource FormLabelStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="按主机名匹配；开启 hosts 区分时结合下方解析 IP"
                                   Style="{StaticResource FormHintStyle}"/>
                        <TextBox x:Name="UrlBox" Style="{StaticResource FormTextBoxStyle}"/>

                        <StackPanel x:Name="SiteEndpointPanel" Margin="0,10,0,0">
                            <TextBlock Text="环境 IP（hosts）" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock x:Name="SiteEndpointHint"
                                       Text="留空：不绑定 IP；保存时可自动填入当前 hosts 解析结果"
                                       Style="{StaticResource FormHintStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SiteEndpointBox" Grid.Column="0"
                                         Style="{StaticResource FormTextBoxStyle}"/>
                                <Button Grid.Column="1" Content="检测 IP"
                                        Click="DetectEndpoint_Click"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        MinHeight="34" Margin="6,0,0,0"
                                        Padding="8,4" FontSize="12"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="自定义字段" Style="{StaticResource FormLabelStyle}" Margin="0,12,0,0"/>
                        <TextBlock Text="银行卡、API、密保等（可选）"
                                   Style="{StaticResource FormHintStyle}"/>
                        <StackPanel x:Name="CustomFieldsPanel" Margin="0,2,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="添加字段" Click="AddField_Click"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Padding="8,4" FontSize="12" MinHeight="28"/>
                            <Button x:Name="TemplateMenuButton" Content="插入模板"
                                    Click="TemplateMenuButton_Click"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Padding="8,4" FontSize="12" MinHeight="28" Margin="6,0,0,0">
                                <Button.ContextMenu>
                                    <ContextMenu MinWidth="280">
                                        <MenuItem Header="银行卡（卡号 / 有效期 / CVV / 持卡人）"
                                                  Click="TemplateBankCard_Click"/>
                                        <MenuItem Header="API 密钥（Client ID / Secret / Endpoint）"
                                                  Click="TemplateApi_Click"/>
                                        <MenuItem Header="密保问题（三组问答）"
                                                  Click="TemplateSecurityQA_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="备注" Style="{StaticResource FormLabelStyle}" Margin="0,12,0,0"/>
                        <TextBox x:Name="NotesBox" Style="{StaticResource FormMultilineTextBoxStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                        Margin="0,12,0,0" Padding="0,12,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="76" Height="32" Margin="0,0,8,0"
                                FontSize="12" IsCancel="True" Click="Cancel_Click"/>
                        <Button Content="保存" Width="76" Height="32"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12" IsDefault="True" Click="Save_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
