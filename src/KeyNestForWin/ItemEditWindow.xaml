<Window x:Class="KeyNestForWin.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="条目"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="标题"/>
        <TextBox x:Name="TitleBox" Margin="0,4,0,12"/>
        <TextBlock Text="用户名"/>
        <TextBox x:Name="UsernameBox" Margin="0,4,0,12"/>
        <TextBlock Text="密码"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,4,0,12"/>
        <TextBlock Text="网站 URL（用于扩展匹配）"/>
        <TextBox x:Name="UrlBox" Margin="0,4,0,12"/>
        <TextBlock Text="备注"/>
        <TextBox x:Name="NotesBox" AcceptsReturn="True" Height="64" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Margin="0,4,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="取消" Width="88" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="保存" Width="88" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
