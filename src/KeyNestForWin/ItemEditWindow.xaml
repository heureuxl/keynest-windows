<Window x:Class="KeyNestForWin.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑条目"
        Height="620" Width="500"
        MinHeight="480" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.WindowBg}">
    <Border Background="{StaticResource Brush.WindowBg}" Padding="20">
        <Border Background="{StaticResource Brush.SurfaceElevated}"
                CornerRadius="16"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="24,20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="28" Opacity="0.35"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="条目详情" Style="{StaticResource TextTitleStyle}" FontSize="20" Margin="0,0,0,6"/>
                    <TextBlock Text="编辑密码条目；浏览器扩展填充仍使用用户名与密码。"
                               Style="{StaticResource TextCaptionStyle}" TextWrapping="Wrap"/>
                    <CheckBox x:Name="FavoriteCheck" Content="收藏（列表优先展示）" Margin="0,12,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="标题" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                        <TextBox x:Name="TitleBox"/>

                        <TextBlock Text="用户名" Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,6"/>
                        <TextBox x:Name="UsernameBox"/>

                        <TextBlock Text="密码" Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,6"/>
                        <Grid MinHeight="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="PasswordBox" Grid.Column="0" MinHeight="40"/>
                            <TextBox x:Name="PasswordPlain" Grid.Column="0" MinHeight="40"
                                     Visibility="Collapsed" VerticalContentAlignment="Center"/>
                            <Button x:Name="PasswordToggle" Grid.Column="1" Content="显示"
                                    Click="PasswordToggle_Click"
                                    Style="{StaticResource GhostButtonStyle}"
                                    MinWidth="56" Margin="10,0,0,0" Padding="12,8"/>
                        </Grid>

                        <TextBlock Text="网站（域名或完整 URL；填充时按主机名匹配）"
                                   Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,6"/>
                        <TextBox x:Name="UrlBox"/>

                        <TextBlock Text="自定义字段" Style="{StaticResource TextCaptionStyle}" Margin="0,16,0,6"/>
                        <TextBlock Text="适用于银行卡、API Key、密保问答等。"
                                   Style="{StaticResource TextCaptionStyle}" FontSize="11" Margin="0,0,0,8"/>
                        <StackPanel x:Name="CustomFieldsPanel"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="添加字段" Click="AddField_Click" Style="{StaticResource ToolbarButtonStyle}"/>
                            <Menu Margin="8,0,0,0" VerticalAlignment="Center">
                                <MenuItem Header="插入字段模板">
                                    <MenuItem Header="银行卡（卡号 / 有效期 / CVV / 持卡人）" Click="TemplateBankCard_Click"/>
                                    <MenuItem Header="API 密钥（Client ID / Secret / Endpoint）" Click="TemplateApi_Click"/>
                                    <MenuItem Header="密保问题（三组问答）" Click="TemplateSecurityQA_Click"/>
                                </MenuItem>
                            </Menu>
                        </StackPanel>

                        <TextBlock Text="备注" Style="{StaticResource TextCaptionStyle}" Margin="0,16,0,6"/>
                        <TextBox x:Name="NotesBox" AcceptsReturn="True" Height="72" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="取消" Width="100" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                    <Button Content="保存" Width="100" Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
