<Window x:Class="KeyNestForWin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBg}">
    <Border Padding="24">
        <Border Background="{StaticResource Brush.SurfaceElevated}"
                CornerRadius="12" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" Padding="24,20">
            <StackPanel MinWidth="380">
                <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,18"/>

                <TextBlock Text="保管库" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="同一网站（主机名）下最多保留的不同用户名账号数"
                           TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="上限" VerticalAlignment="Center" Margin="0,0,12,0"
                               Foreground="{StaticResource Brush.TextSecondary}"/>
                    <TextBox x:Name="MaxAccountsBox" Grid.Column="1" MinWidth="80" MaxWidth="120"
                             HorizontalAlignment="Left"
                             Style="{StaticResource FormTextBoxStyle}"/>
                </Grid>
                <TextBlock Text="范围 1–99；保存后对保管库立即生效。"
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,16"/>

                <TextBlock Text="测试环境（hosts）" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox x:Name="DistinguishHostsByIpCheck"
                          Content="按 hosts / DNS 解析 IP 区分同一域名"
                          Foreground="{StaticResource Brush.Text}"
                          FontSize="13" Margin="0,0,0,6"/>
                <TextBlock Text="开启后：同一域名指向不同 IP 时，账号分开保存与填充；切换 hosts 注释后会自动匹配对应环境。"
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,20"/>

                <Rectangle Height="1" Fill="{StaticResource Brush.Border}" Opacity="0.6" Margin="0,0,0,16"/>

                <TextBlock Text="整理与安全" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Button Content="合并重复条目"
                        Click="MergeDuplicates_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        ToolTip="同站点同用户名仅保留最新一条"/>
                <Button Content="更换恢复密钥"
                        Click="RotateRecoveryKey_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"/>
                <TextBlock Text="更换恢复密钥后，旧密钥立即失效，请务必保存新密钥。"
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,16"/>

                <TextBlock x:Name="SettingsError" Foreground="{StaticResource Brush.Danger}"
                           TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="取消" Width="88" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
                    <Button Content="保存" Width="88" Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True" Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
