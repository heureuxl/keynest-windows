<Window x:Class="KeyNestForWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:kn="clr-namespace:KeyNestForWin.Controls"
        Title="KeyNest"
        Height="640" Width="1020"
        MinHeight="520" MinWidth="800"
        Background="{StaticResource Brush.WindowBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="22,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                            Margin="0,0,12,0" Background="{StaticResource Brush.Accent}"/>
                    <TextBlock Text="KeyNest" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="for Windows" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"
                              VerticalAlignment="Bottom" Margin="10,0,0,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 解锁 / 登录 -->
        <Grid Grid.Row="1" x:Name="LockPanel" Visibility="Visible">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Padding="36,24,36,32" VerticalAlignment="Stretch">
                <Border Background="{StaticResource Brush.SurfaceElevated}"
                        HorizontalAlignment="Stretch"
                        MaxWidth="980"
                        Margin="0,0,0,8"
                        CornerRadius="16"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        Padding="36,28,40,32">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="40" Opacity="0.45"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="解锁保管库" Style="{StaticResource TextTitleStyle}"
                                       FontSize="24" TextAlignment="Left" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LockHint"
                                       Text="输入主密码以解锁保管库，或创建新保管库。"
                                       TextWrapping="Wrap"
                                       TextAlignment="Left"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       Margin="0,8,0,22" LineHeight="24"/>
                            <TextBlock Text="主密码" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <Grid MinHeight="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="MasterPasswordBox" Grid.Column="0" MinHeight="36"/>
                                <TextBox x:Name="MasterPasswordPlain" Grid.Column="0" MinHeight="36"
                                         Visibility="Collapsed" VerticalContentAlignment="Center"/>
                                <Button x:Name="MasterPasswordToggle" Grid.Column="1" Content="显示"
                                        Click="MasterPasswordToggle_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        MinWidth="56" Margin="10,0,0,0" Padding="12,8"/>
                            </Grid>
                            <Button Content="解锁 / 创建"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Left" MinWidth="160"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="Unlock_Click"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                   Fill="{StaticResource Brush.Border}" Opacity="0.55"/>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="忘记主密码" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"/>
                            <TextBlock Text="使用恢复密钥短语重置主密码"
                                       Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,18"
                                       TextWrapping="Wrap" LineHeight="22"/>
                            <TextBlock Text="恢复密钥短语" Style="{StaticResource TextCaptionStyle}" Margin="0,0,0,6"/>
                            <TextBox x:Name="RecoveryPhraseBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                     VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Text="新主密码（至少 8 位）" Style="{StaticResource TextCaptionStyle}" Margin="0,14,0,6"/>
                            <Grid MinHeight="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="NewMasterAfterRecoveryBox" Grid.Column="0" MinHeight="36"/>
                                <TextBox x:Name="NewMasterPlain" Grid.Column="0" MinHeight="36"
                                         Visibility="Collapsed" VerticalContentAlignment="Center"/>
                                <Button x:Name="NewMasterToggle" Grid.Column="1" Content="显示"
                                        Click="NewMasterToggle_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        MinWidth="56" Margin="10,0,0,0" Padding="12,8"/>
                            </Grid>
                            <Button Content="使用恢复密钥重置主密码"
                                    Margin="0,18,0,0" HorizontalAlignment="Left"
                                    Click="RecoveryUnlock_Click"/>
                        </StackPanel>
                        </Grid>
                        <TextBlock x:Name="LockError" Grid.Row="1"
                                   Foreground="{StaticResource Brush.Danger}"
                                   TextWrapping="Wrap" Margin="0,20,0,0" LineHeight="20" TextAlignment="Left"/>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- 主界面 -->
        <Grid Grid.Row="1" x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,0,1" Padding="14,10,14,10">
                <StackPanel Orientation="Horizontal">
                    <Button Content="添加条目" Click="AddItem_Click" Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button Content="编辑" Click="EditItem_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="6,0,0,0"/>
                    <Button Content="删除" Click="DeleteItem_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="6,0,0,0"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.Border}" Margin="16,4" Opacity="0.6"/>
                    <Button Content="设置" Click="Settings_Click" Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="保管库选项、合并重复、更换恢复密钥"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.Border}" Margin="16,4" Opacity="0.6"/>
                    <Button Content="锁定" Click="Lock_Click" Style="{StaticResource ToolbarButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- 筛选栏 -->
            <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,0,1" Padding="16,8,16,10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="160"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                 Style="{StaticResource CompactSearchBoxStyle}"
                                 Background="{StaticResource Brush.InputBg}"
                                 Foreground="{StaticResource Brush.Text}"
                                 CaretBrush="{StaticResource Brush.Text}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 ToolTip="搜索标题、用户名、网站、备注、扩展字段…"
                                 TextChanged="SearchOrFilter_Changed"/>
                        <ComboBox x:Name="FilterCombo" Grid.Column="2" MinWidth="132"
                                  Style="{StaticResource CompactComboBoxStyle}"
                                  Background="{StaticResource Brush.InputBg}"
                                  Foreground="{StaticResource Brush.Text}"
                                  BorderBrush="{StaticResource Brush.Border}"
                                  SelectionChanged="SearchOrFilter_Changed"/>
                        <ComboBox x:Name="LayoutCombo" Grid.Column="4" MinWidth="108"
                                  Style="{StaticResource CompactComboBoxStyle}"
                                  Background="{StaticResource Brush.InputBg}"
                                  Foreground="{StaticResource Brush.Text}"
                                  BorderBrush="{StaticResource Brush.Border}"
                                  SelectionChanged="SearchOrFilter_Changed"/>
                    </Grid>
                    <TextBlock x:Name="FilterCaption" Margin="2,8,0,0"
                               FontSize="12" Foreground="{StaticResource Brush.TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- 列表 + 详情 -->
            <Border Grid.Row="2" Margin="16,8,16,8" CornerRadius="12"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="300" MinWidth="240"/>
                    </Grid.ColumnDefinitions>

                    <ListView x:Name="ItemsList" Grid.Column="0" BorderThickness="0"
                              Background="Transparent"
                              Foreground="{StaticResource Brush.Text}"
                              SelectionChanged="ItemsList_SelectionChanged"
                              MouseDoubleClick="ItemsList_MouseDoubleClick"
                              KeyDown="ItemsList_KeyDown">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="26">
                                    <GridViewColumn.Header>
                                        <TextBlock Text="" ToolTip="拖动左侧手柄调整条目顺序"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <kn:RowReorderGrip ItemId="{Binding Id}"
                                                               Style="{StaticResource RowReorderGripStyle}"
                                                               Loaded="RowGrip_Loaded"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="标题" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <kn:EllipsisTextBlock Text="{Binding Title}"
                                                                  Foreground="{StaticResource Brush.Text}"
                                                                  VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="用户名" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <kn:EllipsisTextBlock Text="{Binding Username}"
                                                                  Foreground="{StaticResource Brush.TextMuted}"
                                                                  VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="网站" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <kn:EllipsisTextBlock Text="{Binding SiteHost}"
                                                                  Foreground="{StaticResource Brush.TextMuted}"
                                                                  VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="操作" Width="116">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                <Button Tag="{Binding Id}"
                                                        ToolTip="收藏 / 取消收藏"
                                                        Click="RowFavorite_Click"
                                                        Style="{StaticResource FavoriteStarButtonStyle}"/>
                                                <Button Content="编辑"
                                                        Tag="{Binding Id}"
                                                        Margin="2,0,0,0"
                                                        Click="RowEdit_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Padding="10,4" MinHeight="28"
                                                        FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   Margin="4,8,0,4"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                    </ListView>

                    <Rectangle Grid.Column="1" Fill="{StaticResource Brush.Border}" Opacity="0.6"/>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="16,14">
                        <StackPanel x:Name="DetailPanel">
                            <TextBlock x:Name="DetailEmptyHint" Text="选择一条记录"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,40,0,0"/>
                            <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                                <TextBlock x:Name="DetailTitle" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="网站" Style="{StaticResource TextCaptionStyle}" Margin="0,16,0,4"/>
                                <TextBlock x:Name="DetailUrl" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}"/>
                                <TextBlock Text="用户名" Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,4"/>
                                <TextBlock x:Name="DetailUsername" TextWrapping="Wrap"/>
                                <TextBlock Text="密码" Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource Brush.InputBg}"
                                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                            CornerRadius="8" Padding="10,8">
                                        <TextBlock x:Name="DetailPassword" FontFamily="Consolas"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.Text}"/>
                                    </Border>
                                    <Button x:Name="DetailRevealBtn" Grid.Column="1" Content="显示"
                                            Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0"
                                            Click="DetailReveal_Click"/>
                                    <Button Grid.Column="2" Content="复制"
                                            Style="{StaticResource GhostButtonStyle}" Margin="6,0,0,0"
                                            Click="DetailCopyPassword_Click"/>
                                </Grid>
                                <TextBlock x:Name="DetailWeakHint" Visibility="Collapsed" Margin="0,8,0,0"
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource Brush.Danger}"
                                           Text="根据本地规则，当前密码偏短或字符类型较少，建议在网站修改后在此更新。"/>
                                <StackPanel x:Name="DetailCustomFieldsPanel" Margin="0,12,0,0"/>
                                <TextBlock Text="备注" Style="{StaticResource TextCaptionStyle}" Margin="0,12,0,4"/>
                                <TextBlock x:Name="DetailNotes" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,1,0,0" Padding="20,14">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Text="凭据不离开本机。"/>
                    <CheckBox x:Name="BridgeToggle"
                              Content="允许浏览器扩展连接本机端口 17373（解锁时生效）"
                              IsChecked="True"
                              VerticalAlignment="Center"
                              Checked="BridgeToggle_Changed" Unchecked="BridgeToggle_Changed"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
