<Window x:Class="KeyNestForWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyNest"
        Height="560" Width="880"
        MinHeight="420" MinWidth="640">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件">
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- 解锁 -->
        <Grid x:Name="LockPanel" Visibility="Visible" Margin="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
                <TextBlock Text="KeyNest" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LockHint" Text="输入主密码以解锁保管库，或创建新保管库。" TextWrapping="Wrap"
                           Margin="0,12,0,8" Foreground="#555" HorizontalAlignment="Center"/>
                <PasswordBox x:Name="MasterPasswordBox" Height="28" Margin="0,8"/>
                <Button Content="解锁 / 创建" Height="36" Margin="0,16,0,8" Click="Unlock_Click"/>
                <Separator Margin="0,16"/>
                <TextBlock Text="忘记主密码（恢复密钥）" FontWeight="SemiBold" Margin="0,8"/>
                <TextBox x:Name="RecoveryPhraseBox" AcceptsReturn="True" TextWrapping="Wrap" Height="72"
                         VerticalScrollBarVisibility="Auto"/>
                <PasswordBox x:Name="NewMasterAfterRecoveryBox" Height="28" Margin="0,8,0,0"/>
                <TextBlock Text="新主密码（至少 8 位）" FontSize="11" Foreground="#666"/>
                <Button Content="使用恢复密钥重置主密码" Margin="0,12,0,0" Click="RecoveryUnlock_Click"/>
                <TextBlock x:Name="LockError" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 主界面 -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ToolBar Grid.Row="0">
                <Button Content="添加条目" Click="AddItem_Click"/>
                <Button Content="编辑" Click="EditItem_Click"/>
                <Button Content="删除" Click="DeleteItem_Click"/>
                <Separator/>
                <Button Content="锁定" Click="Lock_Click"/>
            </ToolBar>
            <DataGrid x:Name="ItemsGrid" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="140"/>
                    <DataGridTextColumn Header="网站 URL" Binding="{Binding Url}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
            <DockPanel Grid.Row="2" Margin="12,8">
                <CheckBox x:Name="BridgeToggle" Content="允许浏览器扩展连接本机端口 17373（解锁时生效）"
                          IsChecked="True"
                          VerticalAlignment="Center" Checked="BridgeToggle_Changed" Unchecked="BridgeToggle_Changed"/>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="11" Foreground="#666"
                           Text="凭据不离开本机。"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
