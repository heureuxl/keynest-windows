<Window x:Class="KeyNestForWin.RecoveryKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存恢复密钥"
        Width="560"
        MinHeight="280"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.WindowBg}">
    <Border Padding="24">
        <Border Background="{StaticResource Brush.SurfaceElevated}"
                CornerRadius="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="24,20">
            <StackPanel>
                <TextBlock Text="重要：恢复密钥仅此一次完整展示" Style="{StaticResource TextTitleStyle}" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,16" LineHeight="22"
                           Text="请复制并保存在安全处。丢失后将无法通过恢复密钥找回保管库。关闭窗口后界面仅保留确认，不会再次显示完整密钥。"/>
                <TextBox x:Name="KeyText"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="140"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas,Courier New,monospace"
                         FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="CopyBtn" Content="复制到剪贴板" Margin="0,0,10,0" Click="Copy_Click"/>
                    <Button Content="我已安全保存" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="Ok_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
